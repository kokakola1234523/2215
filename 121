-- Equip and Eat Helper
local StoreBuyItem = ReplicatedStorage:WaitForChild("StoreBuyItem")

local function unequipTools()
    local character = LocalPlayer.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid:UnequipTools()
    end
end

local function equipAndEat(itemName)
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local backpack = LocalPlayer:WaitForChild("Backpack")
    
    local tool = backpack:FindFirstChild(itemName) or (character and character:FindFirstChild(itemName))
    
    if tool and tool:IsA("Tool") then
        tool.Parent = character
        task.wait(0.5)
        tool:Activate()
        task.wait(1.5)
    end
end

