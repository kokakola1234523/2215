-- មុខងារចុច ProximityPrompt
local function interactWithPrompt(prompt)
    if prompt and prompt:IsA("ProximityPrompt") then
        prompt.RequiresLineOfSight = false
        
        if fireproximityprompt then
            fireproximityprompt(prompt)
        else
            prompt.HoldDuration = 0 
            task.wait(0.05)
            prompt:InputHoldBegin()
            task.wait(0.1) 
            prompt:InputHoldEnd()
        end
    end
end

-- មុខងារពិនិត្យមើល និងស្វែងរកម្ហូប
local function getFoodTool()
    local character = player.Character
    if character and character:FindFirstChild(FOOD_ITEM_NAME) then 
        return character:FindFirstChild(FOOD_ITEM_NAME) 
    end
    if player.Backpack:FindFirstChild(FOOD_ITEM_NAME) then 
        return player.Backpack:FindFirstChild(FOOD_ITEM_NAME) 
    end
    
    if character then
        for _, child in ipairs(character:GetChildren()) do
            if child:IsA("Tool") and string.find(string.lower(child.Name), "food") then 
                return child 
            end
        end
    end
    for _, child in ipairs(player.Backpack:GetChildren()) do
        if child:IsA("Tool") and string.find(string.lower(child.Name), "food") then 
            return child 
        end
    end
    return nil
end

local function hasFood()
    return getFoodTool() ~= nil
end

local function findActiveDeliverySpot(deliveryLocation)
    if not deliveryLocation then return nil end
    for _, spotName in ipairs(spots) do
        local spotPart = deliveryLocation:FindFirstChild(spotName)
        if spotPart and spotPart:IsA("BasePart") then
            if math.abs(spotPart.Transparency - 0.4) < 0.05 then
                return spotPart
            end
        end
    end
    return nil
end

-- Anti-Ban Teleport Engine
local function antiBanTeleport(targetPart)
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart or not targetPart then return end
    
    rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    
    local noclip = RunService.Stepped:Connect(function()
        if character then
            for _, part in pairs(character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)
    
    local offsetX = (math.random(-10, 10) / 10)
    local offsetZ = (math.random(-10, 10) / 10)
    local targetPos = targetPart.Position + Vector3.new(offsetX, 2.0, offsetZ)
    
    rootPart.CFrame = CFrame.new(targetPos)
    
    rootPart.Anchored = true
    task.wait(0.05)
    rootPart.Anchored = false
    
    rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    
    noclip:Disconnect()
    task.wait(0.15)
end

-- Core Delivery Engine Run Routine
local function runDeliveryRoutine()
    while isScriptRunning do
        local character = player.Character or player.CharacterAdded:Wait()
        local rootPart = character:WaitForChild("HumanoidRootPart")
        local humanoid = character:WaitForChild("Humanoid")
        
        local targetPart = workspace.Building["Prop Building"].FoodPickup
        local deliveryLocation = workspace:FindFirstChild("DeliveryLocation")
        
        print("--- Start New Anti-Ban Sequence ---")

        -- វគ្គទី ១: ទៅយកម្ហូប (Collect Food)
        if targetPart and rootPart and not hasFood() then
            local attempt = 0
            while not hasFood() and attempt < 8 and isScriptRunning do
                attempt = attempt + 1
                print("Teleporting to FoodPickup... Attempt: " .. attempt)
                
                antiBanTeleport(targetPart)
                task.wait(0.2) 
                
                local prompt = targetPart:FindFirstChildOfClass("ProximityPrompt")
                if not prompt then
                    prompt = workspace.Building["Prop Building"].FoodPickup:FindFirstChildOfClass("ProximityPrompt")
                end
                
                if prompt then
                    interactWithPrompt(prompt)
                else
                    print("[Warning] ProximityPrompt not found!")
                end
                task.wait(0.4) -- រង់ចាំមើលថាតើទទួលបាន Food ហើយឬនៅ
            end
        end

        if not isScriptRunning then break end
        humanWait(0.2, 0.5)

        -- វគ្គទី ២: យកទៅប្រគល់ (Deliver Food + ពិនិត្យរហូតដល់បាត់ពីដៃ)
        if deliveryLocation and rootPart and hasFood() then
            local activeSpot = nil
            local scanAttempt = 0
            
            -- ស្វែងរកទីតាំងផ្ញើដែលសកម្ម
            while not activeSpot and scanAttempt < 10 and isScriptRunning do
                scanAttempt = scanAttempt + 1
                activeSpot = findActiveDeliverySpot(deliveryLocation)
                if not activeSpot then task.wait(0.1) end
            end
            
            if activeSpot and isScriptRunning then
                print("🎯 Found Spot: " .. activeSpot.Name .. " | Starting Delivery Loop...")
                
                local deliveryAttempt = 0
                -- Loop នេះនឹងរត់រហូតដល់ `hasFood()` ត្រឡប់មក false (ម្ហូបបាត់ពីដៃ/កាតាប) ឬគ្រប់ ៨ ដង
                while hasFood() and deliveryAttempt < 8 and isScriptRunning do
                    deliveryAttempt = deliveryAttempt + 1
                    print("🚀 Delivering... Attempt: " .. deliveryAttempt)
                    
                    -- ធានាថាបានកាន់ម្ហូបជាប់នឹងដៃជានិច្ចពេលកំពុងប្រគល់
                    local foodTool = getFoodTool()
                    if foodTool and foodTool.Parent == player.Backpack then
                        humanoid:EquipTool(foodTool)
                        task.wait(0.2)
                    end
                    
                    -- Teleport ទៅកាន់ទីតាំងដាក់ម្ហូប
                    antiBanTeleport(activeSpot)
                    task.wait(0.2) -- ទុកពេលឱ្យហ្គេមទិន្នន័យដើរទាន់
                    
                    local deliveryPrompt = activeSpot:FindFirstChildOfClass("ProximityPrompt")
                    if deliveryPrompt then
                        interactWithPrompt(deliveryPrompt)
                        print("បានចុចប្រគល់ (DeliveryPrompt)...")
                    else
                        print("[Warning] Delivery ProximityPrompt not found!")
                    end
                    
                    task.wait(0.5) -- រង់ចាំកន្លះវិនាទីដើម្បីផ្ទៀងផ្ទាត់ថាម្ហូបបាត់ពីដៃហើយឬនៅ មុននឹងបន្ត Loop ទៅមុខទៀត
                end
                
                if not hasFood() then
                    print("✅ Successfully Delivered! Food is gone from inventory.")
                    humanWait(1.5, 2.5)
                else
                    print("[Warning] Delivery loop finished but food is still in inventory!")
                end
            else
                print("[Warning] No active delivery zone found!")
            end
        end

        if not isScriptRunning then break end

        -- Safe Cooldown Cycle
        local cooldown = math.random(40, 63)
        print("--- Cycle Finished. Anticheat Spoof Cooldown: " .. cooldown .. "s ---")
        
        for i = 1, cooldown do
            if not isScriptRunning then break end
            task.wait(1)
        end
    end
end

