local function forceClickShake(shakeButton)
    if not shakeButton or not shakeButton.Visible then return end
    
    while shakeButton.Visible and _G.AutoFishingPerfectV16 and not isSelling and not isEating do
        local connections = getconnections or get_signal_cons
        
        if connections then
            for _, clickedConnection in ipairs(connections(shakeButton.MouseButton1Click)) do 
                clickedConnection:Fire() 
            end
            pcall(function()
                for _, clickedConnection in ipairs(connections(shakeButton.Activated)) do 
                    clickedConnection:Fire() 
                end
            end)
        end
        
        if ShakeSystem and ShakeSystem.isActive then
            pcall(function()
                if math.random(1, 10) > 3 then
                    ShakeSystem:HandleClick(nil)
                end
            end)
        end
        task.wait(getHumanizedDelay(0.12, 0.25))
    end
end

