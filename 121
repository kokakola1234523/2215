-- Function សម្រាប់ចុច UI Object ដោយកំណត់ទីតាំងលំអៀង (Offset)
local function autoClickUIWithOffset(guiObject)
    if guiObject and guiObject.AbsolutePosition and guiObject.AbsoluteSize then
        
        -- កំណត់ចម្ងាយដែលចង់ឱ្យចុចចុះក្រោមពីចំណុចកណ្តាល (គិតជា Pixel)
        -- បើចង់ឱ្យចុះក្រោមទៀត បង្កើនលេខនេះ។ បើចង់ឱ្យឡើងលើ ដាក់លេខដក (ឧទាហរណ៍ -10)
        local yOffset = 45

        -- គណនារកចំណុចកណ្តាល X
        local centerX = guiObject.AbsolutePosition.X + (guiObject.AbsoluteSize.X / 2)
        
        -- គណនារកចំណុចកណ្តាល Y រួចបូកថែម Offset ដើម្បីឱ្យចុចចុះក្រោមបន្តិច
        local centerYWithOffset = guiObject.AbsolutePosition.Y + (guiObject.AbsoluteSize.Y / 2) + yOffset
        
        -- បញ្ជាឱ្យប្រព័ន្ធចុច (Touch/Click) ទៅលើទីតាំងដែលបានគណនា
        VirtualInputManager:SendMouseButtonEvent(centerX, centerYWithOffset, 0, true, game, 1)
        task.wait(0.05) -- រង់ចាំបន្តិចដើម្បីឱ្យប្រព័ន្ធទទួលដឹង
        VirtualInputManager:SendMouseButtonEvent(centerX, centerYWithOffset, 0, false, game, 1)
        
        -- បោះពុម្ពប្រាប់ដើម្បីស្រួល Check (អាចលុបចេញបានបើលែងត្រូវការ)
        -- print("Clicked at Y offset: " .. yOffset)
    end
end

