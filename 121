-- Function to click UI Object with offset
local function autoClickUIWithOffset(guiObject)
    if guiObject and guiObject.AbsolutePosition and guiObject.AbsoluteSize then
        local yOffset = 45
        local centerX = guiObject.AbsolutePosition.X + (guiObject.AbsoluteSize.X / 2)
        local centerYWithOffset = guiObject.AbsolutePosition.Y + (guiObject.AbsoluteSize.Y / 2) + yOffset
        
        VirtualInputManager:SendMouseButtonEvent(centerX, centerYWithOffset, 0, true, game, 1)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(centerX, centerYWithOffset, 0, false, game, 1)
    end
end

