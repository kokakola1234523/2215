-- បង្កើត អនុគមន៍សម្រាប់ឱ្យតួអង្គកាន់ និងញ៉ាំវត្ថុ
local function equipAndEat(itemName)
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local backpack = LocalPlayer:WaitForChild("Backpack")
    
    -- ស្វែងរកវត្ថុនៅក្នុង Backpack
    local tool = backpack:FindFirstChild(itemName)
    
    -- បើសិនជារកមិនឃើញនៅក្នុង Backpack ទេ ក្រឡេកមើលក្នុងដៃតួអង្គ
    if not tool and character then
        tool = character:FindFirstChild(itemName)
    end
    
    if tool and tool:IsA("Tool") then
        -- បំពាក់វត្ថុនោះទៅឱ្យតួអង្គកាន់នឹងដៃ
        tool.Parent = character
        task.wait(0.5) -- រង់ចាំឱ្យតួអង្គកាន់ជាប់ស្រួលបួល
        
        -- ធ្វើការចុចប្រើប្រាស់ (Eat)
        tool:Activate()
        task.wait(1.5) -- រង់ចាំឱ្យសកម្មភាពញ៉ាំចប់ជាស្ថាពរ
    end
end

